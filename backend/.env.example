# Copy this file to .env and fill in real values before running.

ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql://inspection_user:inspection_pass@db:5432/inspection_db

SECRET_KEY=replace_this_with_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=480

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=15

MODEL_DIR=ai_models/weights
PRODUCT_DETECTION_MODEL=product_detector.pt
COMPONENT_DETECTION_MODEL=component_detector.pt
DEFECT_DETECTION_MODEL=defect_detector.pt
CONFIDENCE_THRESHOLD=0.5

ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
